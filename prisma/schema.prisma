generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/* =========================
   ENUMS
========================= */

enum ProductCategory {
  biodigesters
  grease_traps
  maintenance
  other
}

enum BudgetStatus {
  draft
  sent
  approved
  rejected
  expired
}

enum ClientType {
  home
  permanent_use
  hall
  sanitary
  company
}

enum StockMovementType {
  in
  out
  adjust
}

/* =========================
   MODELS
========================= */

model Client {
  id        String   @id @default(uuid())

  // Identidad
  name      String
  lastName  String?
  company   String?
  dni       String?
  cuit      String?

  // Contacto
  email     String
  phone     String

  // Dirección
  address   String

  // Ubicación
  latitude  Float?
  longitude Float?

  // Uso
  type            ClientType?
  peopleCount     Int?
  usageFrequency  String?

  // Comercial
  status    String   @default("nuevo")
  notes     String   @default("")
  lastContactAt   DateTime?
  assignedSeller  String?
  locationUrl     String?

  // Relaciones
  budgets   Budget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductService {
  id          String           @id @default(uuid())
  name        String
  description String
  category    ProductCategory
  price       Float
  unit        String
  active      Boolean          @default(true)

  stock       Int              @default(0)

  items          BudgetItem[]
  stockMovements StockMovement[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Budget {
  id        String        @id @default(uuid())

  clientId String
  client   Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  items    BudgetItem[]
  history  BudgetStatusHistory[]

  status   BudgetStatus  @default(draft)
  notes    String        @default("")

  // Vendedor
  sellerId String?
  seller   Seller? @relation(fields: [sellerId], references: [id], onDelete: SetNull)

  // Instalador
  installerId String?
  installer   Installer? @relation(fields: [installerId], references: [id], onDelete: SetNull)

  // Instalación
  installationResponsible String?
  installerReference      String?
  siteDetails             String?
  technicalDetails        String?

  // Montos
  subtotal     Float
  discount     Float         @default(0)
  tax          Float         @default(0)
  shippingCost Float?
  total        Float

  // Comerciales
  paymentTerms String?
  validUntil   DateTime?

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Installer {
  id        String   @id @default(uuid())

  name      String
  lastName  String
  phone     String
  email     String?
  city      String?

  budgets   Budget[]

  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Seller {
  id        String   @id @default(uuid())

  name      String
  lastName  String
  dni       String?
  email     String?
  phone     String?

  address   String?
  city      String?
  province  String?
  sector    String?

  budgets Budget[]

  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BudgetItem {
  id               String          @id @default(uuid())

  budgetId         String
  budget           Budget          @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  productServiceId String
  productService   ProductService  @relation(fields: [productServiceId], references: [id])

  quantity         Int
  unitPrice        Float
  discount         Float           @default(0)
  subtotal         Float?
}

model BudgetStatusHistory {
  id        String   @id @default(uuid())

  budgetId  String
  budget    Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  from      BudgetStatus
  to        BudgetStatus
  changedAt DateTime @default(now())
  user      String?
}

model StockMovement {
  id               String   @id @default(cuid())

  productServiceId String
  productService   ProductService @relation(fields: [productServiceId], references: [id])

  delta  Int
  type   StockMovementType
  reason String?

  createdAt DateTime @default(now())
}